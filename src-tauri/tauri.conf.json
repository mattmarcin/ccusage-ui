{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ccusage UI",
  "version": "0.1.0",
  "identifier": "com.mattmarcin.ccusageui",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ccusage UI",
        "width": 1200,
        "height": 800,
        "minWidth": 880,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}